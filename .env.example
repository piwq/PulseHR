# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Postgres (контейнер db). Для SQLite-fallback — закомментируй и используй строку ниже.
DATABASE_URL=postgres://pulse:pulse@db:5432/pulse
# DATABASE_URL=sqlite:////app/db.sqlite3

# Автосоздание суперюзера для админки (CRUD опросов)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Telegram (bot, outbound-only) ---
# Пусто = bot не падает, просто логирует отсутствие токена и крутится вхолостую.
TELEGRAM_BOT_TOKEN=
MANAGER_CHAT_ID=

# --- LLM ---
# fallback = rule-based (без сети). yandexgpt / ollama — [уточнить по ТЗ].
LLM_PROVIDER=fallback

# --- ИИ-отчёт по опросу (Groq) ---
# Бесплатный ключ: https://console.groq.com/keys . Пусто → _fallback_report (без сети).
# Смена провайдера = новый адаптер в apps/insights/llm.py + AI_REPORT_PROVIDER=<name>.
AI_REPORT_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Минимум ответов, при котором опрос допускается к ИИ-отчёту.
AI_REPORT_MIN_RESPONSES=10

# --- Auth / роли ---
# Телефоны, получающие роль HR при первом OTP-входе (через запятую).
HR_PHONES=+79990000000

# --- Notifications / Web Push ---
PUBLIC_BASE_URL=http://localhost
TELEGRAM_BOT_USERNAME=
# Сгенерировать пару: docker compose exec core python manage.py gen_vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:admin@pulsehr.local
# Демо: схлопывает таймеры каскада до N секунд (пусто = боевые 4ч/8ч/7д).
NOTIF_DEMO_SECONDS=20
NOTIF_SMS_ANYTIME=1

# --- Авто-петля инсайтов (closed-loop) ---
# 1 = система сама детектит просадку отделов → Insight → TG-алерт + SSE-тост (без кнопки HR).
# 0 = только ручной analyze (контроль момента на демо).
INSIGHTS_AUTO=0
# Кулдаун дедупа инсайтов, сек (по умолч. 6ч): один алерт на (опрос, отдел, severity).
# Для повторного прогона демо понизить (напр. 60), чтобы алерт сработал снова.
INSIGHTS_COOLDOWN=21600
